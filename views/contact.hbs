<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://public.codepenassets.com/css/normalize-5.0.0.min.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/
font-awesome/6.7.2/css/all.min.css">

    <link rel="icon" href="/images/A.png">
</head>

<body class="contact-body">
    <div class="nav-wrapper">
        <nav class="nav">
            {{> navbar}}
        </nav>
    </div>

    <div class="contact-page">
        <div class="contact-container">
            <div class="form-box" id="Contact-form">
                <h2>Contact</h2>
                <div class="contact-detail">
                    <ul>
                        <li>👤 Name: Anil Chouhan</li>
                        <li>📧 Email: anilchouhan1st@gmail.com</li>
                        <li>📱 Phone (optional)</li>
                        <li>📍 City, State : Madhya Pradesh, India</li>
                        <li>🎓 Student / Full Stack Developer</li>
                        <li>⏰ Usually replies within 24 hours</li>
                    </ul>
                
                </div>
                
            </div>
        </div>
    </div>

    <div class="socialMedia">
        <ul class="social">

            <li data-tooltip="Twitter" style="--bg: #101419">
                <a href="https://twitter.com/optimisticweb" aria-label="Twitter">
                    <i class="fa-brands fa-x-twitter"></i>
                </a>
            </li>

            <li data-tooltip="YouTube" style="--bg: #ff0000">
                <a href="https://www.youtube.com/@optimisticweb" aria-label="YouTube">
                    <i class="fa-brands fa-youtube"></i>
                </a>
            </li>

            <li data-tooltip="Instagram"
                style="--bg: linear-gradient(-45deg, #feda75, #fa7e1e, #d62976, #962fbf, #4f5bd5)">
                <a href="https://www.instagram.com/optimisticweb" aria-label="Instagram">
                    <i class="fa-brands fa-instagram"></i>
                </a>
            </li>        
        </ul>
    </div>
    </div>

    <footer>
        © 2026 My Website | All Rights Reserved | Created by Anil
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
    <script src="/js/navbar.js"></script>
</body>

</html>